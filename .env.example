# Indian Market Data Platform

# Data directory (absolute or relative path)
DATA_DIR=./data

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum number of parallel download workers
MAX_WORKERS=4

# Rate limit: max requests per second to yfinance
RATE_LIMIT_PER_SECOND=2.0

# Retry configuration
RETRY_ATTEMPTS=3
RETRY_WAIT_SECONDS=5.0

# yfinance thread count per batch download call
YFINANCE_THREADS=2

# Anti-blocking: pause after N successful downloads
BATCH_COOLDOWN_SIZE=50

# Anti-blocking: cooldown duration in seconds
BATCH_COOLDOWN_SECS=30.0

# --- HuggingFace Hub ---
# Dataset repository ID (e.g. your-username/indian-market-data)
HF_REPO_ID=
# Write-access token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=
# Set to true for a private dataset repo
HF_PRIVATE=false
